# Copy this file to .env and fill in your real values.
# -------------------------------------------------------

# IBM Quantum API token (required)
# Get your token at: https://quantum.ibm.com/account
IBM_QUANTUM_TOKEN=your_token_here

# -------------------------------------------------------
# Azure Quantum workspace (optional — for Quantinuum access)
# Create a workspace at: https://portal.azure.com (search "Azure Quantum")
# Resource ID is on the workspace's Overview page ("JSON View" -> resourceId,
# or build it from subscription/resource-group/workspace-name yourself):
#   /subscriptions/<sub-id>/resourceGroups/<rg>/providers/Microsoft.Quantum/Workspaces/<name>
# Location is the region shown on that same Overview page (e.g. eastus).
# -------------------------------------------------------
AZURE_QUANTUM_RESOURCE_ID=/subscriptions/your-sub-id/resourceGroups/your-rg/providers/Microsoft.Quantum/Workspaces/your-workspace
AZURE_QUANTUM_LOCATION=eastus
# Required if your Microsoft account belongs to multiple tenants (e.g. a
# personal account signing into a work/school-owned subscription) --
# otherwise device-code login may authenticate against the wrong tenant.
AZURE_QUANTUM_TENANT_ID=your-tenant-id-guid

# -------------------------------------------------------
# LLM Provider (pick ONE — default is anthropic)
# Supported: anthropic, gemini, ollama, openai, vllm
# -------------------------------------------------------
LLM_PROVIDER=anthropic

# --- Option 1: Anthropic (Claude) ---
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Option 2: Google Gemini (free tier available) ---
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=your_gemini_key_here
# GEMINI_MODEL=gemini-2.0-flash

# --- Option 3: Ollama (free, runs locally, no API key needed) ---
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434   # default, change if remote

# --- Option 4: OpenAI ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-4o-mini

# --- Option 5: vLLM (self-hosted open-source models) ---
# LLM_PROVIDER=vllm
# VLLM_BASE_URL=http://your-vllm-server:8000
# VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct

# -------------------------------------------------------
# HTTP Server Configuration (optional)
# -------------------------------------------------------
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8000
MCP_CORS_ORIGINS=*

# API Key Authentication (optional, recommended for production)
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
#MCP_API_KEY=your_secure_api_key_here
